#!/usr/bin/env python3
from __future__ import annotations

import json
from pathlib import Path
import sys

PROJECT_ROOT = Path(__file__).resolve().parent
SRC_ROOT = PROJECT_ROOT / "src"
if str(SRC_ROOT) not in sys.path:
    sys.path.insert(0, str(SRC_ROOT))

from yomi_corpus.pipeline import PipelineWorkspace


def main() -> None:
    args = sys.argv[1:]
    if len(args) > 1:
        raise SystemExit("Usage: status | status dev")
    track_name = args[0] if args else "working"
    workspace = PipelineWorkspace(PROJECT_ROOT)
    summary = workspace.status(track_name=track_name)
    print(json.dumps(summary, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
