#!/usr/bin/env python3
from __future__ import annotations

import json
from pathlib import Path
import sys

PROJECT_ROOT = Path(__file__).resolve().parent
SRC_ROOT = PROJECT_ROOT / "src"
if str(SRC_ROOT) not in sys.path:
    sys.path.insert(0, str(SRC_ROOT))

from yomi_corpus.pipeline import PipelineWorkspace


def main() -> None:
    args = sys.argv[1:]
    if len(args) == 1:
        track_name = "working"
        target_documents = int(args[0])
    elif len(args) == 2:
        track_name = args[0]
        target_documents = int(args[1])
    else:
        raise SystemExit("Usage: prepare <documents> | prepare dev <documents>")

    workspace = PipelineWorkspace(PROJECT_ROOT)
    summary = workspace.prepare_next_batch(
        track_name=track_name,
        target_documents=target_documents,
    )
    print(json.dumps(summary, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
